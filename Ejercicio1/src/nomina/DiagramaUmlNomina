@startuml
   abstract class Empleado {
        
        # String identificacion
        # String nombre
        # int edad
        # int anioIngreso
        # double salarioBasico
        + Empleado(String, String, int, int, double)
       {abstract} + calcularBonificacion() : double
       {abstract} + liquidarNomina() : double*
    }

    class Vendedor {
        - double totalVentas
        - double comision
        - double descuento
        - double neto
        + Vendedor(String, String, int, int, double, double)
        + calcularComision() : double
        + calcularBonificacion() : double
        + liquidarNomina() : double
        + toString() : String
  }

    class Repartidor {
        - int numeroRepartos
        - char zona
        - double valorPorReparto
        - double pagoRepartos
        - double descuento
        - double neto
        + Repartidor(String, String, int, int, double, int, char)
        - validarZona(char) : char
        + calcularPagoRepartos() : double
        + calcularBonificacion() : double
        + liquidarNomina() : double
        + toString() : String
    }

    class ArrayList{
     -ArrayList<Empleado> empleados: Empleado
}

    class Empresa {
        + main(String[] args)$
    }

    Empleado <|-- Vendedor : Herencia
    Empleado <|-- Repartidor : Herencia
    Empresa ..> ArrayList : Usa
    Empresa ..> Empleado : Usa
  

@enduml
